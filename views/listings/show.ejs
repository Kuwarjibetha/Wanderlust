<%- layout("/layouts/boilerplate") %>

  <div class="container mt-4 show-card" style="max-width: 900px;">

    <!-- Title -->
    <h2 class="fw-bold mb-1">
      <%= listings.title %>
    </h2>
    <p class="text-muted mb-3">📍 <%= listings.location %>, <%= listings.country %>
    </p>

    <!-- Image -->
    <img src="<%= listings.image.url %>" alt="listing_image" class="w-100 rounded-4 mb-4"
      style="height: 420px; object-fit: cover;" />

    <!-- Two Column Row -->
    <div class="row g-4">

      <!-- Left -->
      <div class="col-md-7">
        <div class="border rounded-4 p-4 h-100">
          <h5 class="fw-bold mb-3">About this place</h5>
          <p class="text-muted">
            <%= listings.description %>
          </p>
          <hr>
          <% if (listings.owner) { %>
            <p class="mb-0"> <b>Hosted by:</b>
              <%= listings.owner.username %>
            </p>
            <% } %>
              <p class="mb-2"><b>Location:</b> 📍 <%= listings.location %>, <%= listings.country %>
              </p>


              <p class="mb-2"><b>Price:</b>
                <span class="text-danger fw-bold">
                  &#8377;<%= listings.price.toLocaleString("en-in") %>
                </span> / night
              </p>
              <p class="mb-2">
                👥 <b>Max Persons:</b>
                <span class="fw-bold">
                  <%= listings.maxPersons || 1 %> persons
                </span>
              </p>

              <p class="mb-2"><b>Near:</b>
                <%=listings.nearbyPlace.name %>, <%=listings.nearbyPlace.type%> , <%=listings.nearbyPlace.distance%>
              </p>
        </div>
      </div>

      <!-- Right: Action -->
      <div class="col-md-5">
        <div class="border rounded-4 p-4 shadow-sm">
          <h5 class="fw-bold">
            <span class="text-danger">&#8377;<%= listings.price.toLocaleString("en-in") %></span>
            <small class="text-muted fw-normal fs-6">/ night</small>
          </h5>
          <hr>

          <% if (currUser && currUser.role==="guest" ) { %>
            <a href="/listings/<%= listings._id %>/book" class="btn btn-danger w-100 py-2 rounded-3 fw-bold">
              🏨 Book Now
            </a>
            <p class="text-center text-muted mt-2" style="font-size:0.85rem;">
              You won't be charged yet
            </p>
            <% } %>

              <% if (currUser && listings.owner && listings.owner.equals(currUser._id)) { %>
                <a href="/listings/<%= listings._id %>/edit" class="btn btn-outline-dark w-100 mb-2 rounded-3">
                  Edit Listing
                </a>
                <form action="/listings/<%= listings._id %>?_method=DELETE" method="POST">
                  <button class="btn btn-outline-danger w-100 rounded-3">
                    Delete Listing
                  </button>
                </form>
                <% } %>

        </div>
      </div>

    </div>

    <!--  REVIEWS SECTION -->

    <div class="mt-5">

      <!-- Average Rating -->
      <% if (listings.reviews.length> 0) { %>
        <% let total=0; for (let r of listings.reviews) total +=r.rating; let avg=(total /
          listings.reviews.length).toFixed(1); %>
          <div class="mb-3">
            <span style="font-size: 1.5rem;">
              <% for(let i=1; i <=5; i++) { %>
                <%= i <=Math.round(avg) ? "⭐" : "☆" %>
                  <% } %>
            </span>
            <span class="fw-bold fs-5">
              <%= avg %>
            </span>
            <span class="text-muted">
              (<%= listings.reviews.length %> review<%= listings.reviews.length> 1 ? "s" : "" %>)
            </span>
          </div>
          <% } %>

            <h4 class="fw-bold mb-4">Reviews</h4>

            <!-- Review Form — only for guests -->
            <% if (currUser && currUser.role==="guest" ) { %>
              <div class="card border rounded-4 p-4 mb-4 shadow-sm">
                <h5 class="fw-bold mb-3">Leave a Review ✍️</h5>
                <form action="/listings/<%= listings._id %>/reviews" method="POST">

                  <!-- Star Rating -->
                  <div class="mb-3">
                    <label class="form-label fw-semibold">Your Rating</label>
                    <div class="d-flex gap-3">
                      <% for(let i=1; i <=5; i++) { %>
                        <div class="form-check">
                          <input class="form-check-input" type="radio" name="rating" value="<%= i %>" id="star<%= i %>"
                            required />
                          <label class="form-check-label" for="star<%= i %>">
                            <%= i %>⭐
                          </label>
                        </div>
                        <% } %>
                    </div>
                  </div>

                  <!-- Comment -->
                  <div class="mb-3">
                    <label class="form-label fw-semibold">Your Comment</label>
                    <textarea name="comment" class="form-control" rows="3" placeholder="Share your experience..."
                      required></textarea>
                  </div>

                  <button class="btn btn-danger px-4">Submit Review</button>
                </form>
              </div>
              <% } %>

                <!-- Display Reviews -->
                <% if (listings.reviews.length===0) { %>
                  <div class="alert alert-light border text-center">
                    No reviews yet. Be the first to review! ⭐
                  </div>
                  <% } else { %>
                    <div class="row g-3 mb-5">
                      <% for (let review of listings.reviews) { %>
                        <div class="col-12">
                          <div class="card border rounded-4 p-3 shadow-sm">
                            <div class="d-flex justify-content-between align-items-start">

                              <div>
                                <p class="fw-bold mb-1">
                                  👤 <%= review.author ? review.author.username : "Anonymous" %>
                                    <span class="text-muted fw-normal" style="font-size:0.85rem;">
                                      · <%= new Date(review.createdAt).toDateString() %>
                                    </span>
                                </p>
                                <p class="mb-1">
                                  <% for(let i=1; i <=5; i++) { %>
                                    <%= i <=review.rating ? "⭐" : "☆" %>
                                      <% } %>
                                </p>
                                <p class="mb-0 text-muted">
                                  <%= review.comment %>
                                </p>
                              </div>

                              <!-- Delete — only review author -->
                              <% if (currUser && review.author && review.author.equals(currUser._id)) { %>
                                <form action="/listings/<%= listings._id %>/reviews/<%= review._id %>?_method=DELETE"
                                  method="POST">
                                  <button class="btn btn-sm btn-outline-danger">🗑️</button>
                                </form>
                                <% } %>

                            </div>
                          </div>
                        </div>
                        <% } %>
                    </div>
                    <% } %>

    </div>

  </div>