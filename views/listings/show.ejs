<%- layout("/layouts/boilerplate") %>
    <div class="row sh-bod">
        <div class="col-8 offset-3">

            <h3>Listing Details :</h3>
        </div>
        <div class="card col-6 offset-3 show-card">
            <img src="<%= listings.image %>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body">
                <p class="card-text">
                    <b>
                        <%=listings.title %>
                    </b> <br>
                    <%=listings.description %> <br>
                        &#8377; <%=listings.price.toLocaleString("en-in") %><br>
                            <%=listings.location %> <br>
                                <%=listings.country %>
                </p>
            </div>
        </div>

        <br>
        <div class="btns">
            <a href="/listings/<%= listings._id %>/edit" class="btn btn-dark col-1 offset-3 sh-edit-btns">Edit</a>

            <form action="/listings/<%= listings._id %>?_method=DELETE" method="POST">
                <button class="btn btn-dark offset-5 sh-del-btns">Delete</button>
            </form>
        </div>


    </div>