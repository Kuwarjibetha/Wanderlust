<%- layout("/layouts/boilerplate") %>

  <div class="container mt-4 show-card" style="max-width: 900px;">

    <!-- title -->
    <h2 class="fw-bold mb-1">
      <%= listings.title %>
    </h2>
    <p class="text-muted mb-3">📍 <%= listings.location %>, <%= listings.country %>
    </p>

    <!-- image -->
    <img src="<%= listings.image.url %>" alt="listing_image" class="w-100 rounded-4 mb-4"
      style="height: 420px; object-fit: cover;" />

    <!-- two column Rrow -->
    <div class="row g-4">

      <!-- left side kaa-->
      <div class="col-md-7">
        <div class="border rounded-4 p-4 h-100">
          <h5 class="fw-bold mb-3">About this place</h5>
          <p class="text-muted">
            <%= listings.description %>
          </p>
          <hr>
          <% if (listings.owner) { %>
            <p class="mb-0"> <b>Hosted by:</b>
              <%= listings.owner.username %>
            </p>
            <% } %>
              <p class="mb-2"><b>Location:</b> 📍 <%= listings.location %>, <%= listings.country %>
              </p>


              <p class="mb-2"><b>Price:</b>
                <span class="text-danger fw-bold">
                  &#8377;<%= listings.price.toLocaleString("en-in") %>
                </span> / night
              </p>
              <p class="mb-2">
                👥 <b>Max Persons:</b>
                <span class="fw-bold">
                  <%= listings.maxPersons || 1 %> persons
                </span>
              </p>

              <p class="mb-2"><b>Near:</b>
                <%=listings.nearbyPlace.name %>, <%=listings.nearbyPlace.type%> , <%=listings.nearbyPlace.distance%>
              </p>
        </div>
      </div>

      <!-- Right side kaa -->
      <div class="col-md-5">
        <div class="border rounded-4 p-4 shadow-sm">
          <h5 class="fw-bold">
            <span class="text-danger">&#8377;<%= listings.price.toLocaleString("en-in") %></span>
            <small class="text-muted fw-normal fs-6">/ night</small>
          </h5>
          <hr>

          <% if (currUser && currUser.role==="guest" ) { %>
            <a href="/listings/<%= listings._id %>/book" class="btn btn-danger w-100 py-2 rounded-3 fw-bold">
              🏨 Book Now
            </a>
            <p class="text-center text-muted mt-2" style="font-size:0.85rem;">
              You won't be charged yet
            </p>
            <% } %>



              <!-- AI trip planner  awsome response first i use gemnni after limit then use ollama-->
              <% if (currUser && currUser.role==="guest" ) { %>
                <hr>
                <p class="fw-semibold mb-2">🗺️ Plan Your Trip</p>
                <div class="d-flex gap-2">
                  <input type="number" id="tripDays" class="form-control rounded-3" placeholder="Days" min="1" max="14"
                    value="3" />
                  <button type="button" id="tripBtn" class="btn btn-outline-danger rounded-3 fw-bold"
                    onclick="planTrip('<%= listings._id %>')" style="white-space: nowrap;">
                    ✨ Plan
                  </button>
                </div>

                <!-- Loading -->
                <div id="tripLoading" style="display:none;" class="mt-2">
                  <div class="spinner-border spinner-border-sm text-danger" role="status"></div>
                  <small class="text-muted ms-2">AI is planning your trip...</small>
                </div>
                <% } %>

                  <% if (currUser && listings.owner && listings.owner.equals(currUser._id)) { %>
                    <a href="/listings/<%= listings._id %>/edit" class="btn btn-outline-dark w-100 mb-2 rounded-3">
                      Edit Listing
                    </a>
                    <form action="/listings/<%= listings._id %>?_method=DELETE" method="POST">
                      <button class="btn btn-outline-danger w-100 rounded-3">
                        Delete Listing
                      </button>
                    </form>
                    <% } %>

        </div>
      </div>

    </div>

    <!-- ── AI trip planner Result ── -->
    <div id="tripPlanBox" style="display:none;" class="container mt-4" style="max-width:900px;">
      <div class="card border-0 shadow-sm rounded-4 p-4" style="background: linear-gradient(135deg, #fff5f5, #fff);">

        <div class="d-flex align-items-center gap-2 mb-3">
          <span style="font-size:1.5rem;">🗺️</span>
          <h5 class="fw-bold mb-0" style="color:#e74c3c;">
            Your AI Trip Itinerary
          </h5>
          <button onclick="document.getElementById('tripPlanBox').style.display='none'"
            class="btn btn-sm btn-outline-secondary rounded-3 ms-auto">
            ✕ Close
          </button>
        </div>

        <div id="tripContent" class="text-muted" style="white-space: pre-line; line-height: 1.8;">
        </div>

        <div class="mt-3">
          <a href="/listings/<%= listings._id %>/book" class="btn btn-danger rounded-3 px-4">
            🏨 Book Now
          </a>
        </div>

      </div>
    </div>

    <!--  review section hai  -->

    <div class="mt-5">

      <!-- average rating  check -->
      <% if (listings.reviews.length> 0) { %>
        <% let total=0; for (let r of listings.reviews) total +=r.rating; let avg=(total /
          listings.reviews.length).toFixed(1); %>
          <div class="mb-3">
            <span style="font-size: 1.5rem;">
              <% for(let i=1; i <=5; i++) { %>
                <%= i <=Math.round(avg) ? "⭐" : "☆" %>
                  <% } %>
            </span>
            <span class="fw-bold fs-5">
              <%= avg %>
            </span>
            <span class="text-muted">
              (<%= listings.reviews.length %> review<%= listings.reviews.length> 1 ? "s" : "" %>)
            </span>
          </div>
          <% } %>

            <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
              <h4 class="fw-bold mb-0">Reviews</h4>

              <!-- AI summarize button -->
              <% if (listings.reviews.length> 0) { %>
                <button type="button" id="summarizeBtn" class="btn btn-sm btn-outline-danger rounded-3"
                  onclick="summarizeReviews('<%= listings._id %>')">
                  ✨ AI Summary
                </button>
                <% } %>
            </div>

            <!-- AI summary box (hidden by default) -->
            <div id="summaryBox" style="display:none;" class="alert border rounded-4 p-3 mb-4"
              style="background: #fff5f5; border-color: #ffcccc;">
              <div class="d-flex align-items-start gap-2">
                <span style="font-size:1.5rem;">🤖</span>
                <div>
                  <p class="fw-bold mb-1" style="color:#e74c3c;">AI Review Summary</p>
                  <p id="summaryText" class="mb-0 text-muted"></p>
                </div>
              </div>
            </div>

            <!-- loading  ho raha hai -->
            <div id="summaryLoading" style="display:none;" class="mb-3">
              <div class="spinner-border spinner-border-sm text-danger" role="status"></div>
              <small class="text-muted ms-2">AI is reading reviews...</small>
            </div>

            <!-- Add review form (guests only) -->
            <% if (currUser && currUser.role==="guest" ) { %>
              <form action="/listings/<%= listings._id %>/reviews" method="POST" class="border rounded-4 p-3 mb-4">
                <h6 class="fw-bold mb-3">Leave a Review</h6>
                <div class="mb-3">
                  <label class="form-label">Rating</label>
                  <select name="rating" class="form-select" required>
                    <option value="">Choose rating</option>
                    <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                    <option value="4">⭐⭐⭐⭐ (4)</option>
                    <option value="3">⭐⭐⭐ (3)</option>
                    <option value="2">⭐⭐ (2)</option>
                    <option value="1">⭐ (1)</option>
                  </select>
                </div>
                <div class="mb-3">
                  <label class="form-label">Comment</label>
                  <textarea name="comment" class="form-control" rows="3" required></textarea>
                </div>
                <button type="submit" class="btn btn-danger rounded-3">Submit Review</button>
              </form>
              <% } %>

                <!-- Review cards -->
                <% if (listings.reviews.length===0) { %>
                  <p class="text-muted">No reviews yet. Be the first to review!</p>
                  <% } else { %>
                    <div class="row g-3">
                      <% for (let review of listings.reviews) { %>
                        <div class="col-md-6">
                          <div class="border rounded-4 p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                              <b>
                                <%= review.author ? review.author.username : "Anonymous" %>
                              </b>
                              <span class="text-warning">
                                <% for (let i=1; i <=5; i++) { %>
                                  <%= i <=review.rating ? "⭐" : "☆" %>
                                    <% } %>
                              </span>
                            </div>
                            <p class="text-muted mb-2">
                              <%= review.comment %>
                            </p>
                            <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
                              <form action="/listings/<%= listings._id %>/reviews/<%= review._id %>?_method=DELETE"
                                method="POST">
                                <button class="btn btn-sm btn-outline-danger rounded-3">Delete</button>
                              </form>
                              <% } %>
                          </div>
                        </div>
                        <% } %>
                    </div>
                    <% } %>
    </div>

    <!-- ── AI Chatbot Bubble ── -->
    <% if (currUser && currUser.role==="guest" ) { %>

      <!-- Chat Bubble Button -->
      <button onclick="toggleChat()" class="ai-chat-bub" title="Ask AI about this listing">💬
      </button>

      <!-- Chat Window -->
      <div id="chatWindow" class="ai-chat-window">

        <!-- Chat Header -->
        <div class="chat-header">
          <div>
            <p class="fw-bold mb-0">🤖 AI Assistant</p>
            <small style="opacity:0.8;">Ask anything about this listing</small>
          </div>
          <button onclick="toggleChat()"
            style="background:none; border:none; color:white; font-size:1.2rem; cursor:pointer;">
            ✕
          </button>
        </div>

        <!-- Chat Messages -->
        <div class="chat-messages" id="chatMessages">
          <!-- Welcome message -->
          <div class="welcome-message">
            👋 Hi! I'm your AI assistant. Ask me anything about <b>
              <%= listings.title %>
            </b>!
          </div>
        </div>

        <!-- Chat Input -->
        <div class="chat-input">
          <input type="text" id="chatInput" placeholder="Ask a question..." class="form-control rounded-3"
            style="font-size: 0.9rem;" onkeypress="if(event.key==='Enter') sendMessage()" />
          <button onclick="sendMessage()" id="sendBtn" class="btn btn-danger rounded-3 px-3">
            ➤
          </button>
        </div>

      </div>

      <% } %>
  </div>
  <script>
    //  Chatbot 
    let chatOpen = false;
    const listingId = "<%= listings._id %>";

    function toggleChat() {
      chatOpen = !chatOpen;
      document.getElementById("chatWindow").style.display = chatOpen ? "flex" : "none";
      if (chatOpen) {
        document.getElementById("chatInput").focus();
      }
    }

    async function sendMessage() {
      const input = document.getElementById("chatInput");
      const message = input.value.trim();
      if (!message) return;

      addMessage(message, "user");
      input.value = "";

      const typingId = addTyping();

      try {
        const response = await fetch(`/listings/${listingId}/chat`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ message }),
        });

        const data = await response.json();
        removeTyping(typingId);

        if (data.success) {
          addMessage(data.reply, "ai");
        } else {
          addMessage("Sorry, I'm busy right now! Try again. 🙏", "ai");
        }
      } catch (err) {
        removeTyping(typingId);
        addMessage("Something went wrong! Try again.", "ai");
      }
    }

    function addMessage(text, sender) {
      const messages = document.getElementById("chatMessages");
      const div = document.createElement("div");

      div.style.cssText = `
      padding: 10px 14px;
      border-radius: ${sender === "user" ? "12px 12px 0 12px" : "12px 12px 12px 0"};
      max-width: 85%;
      font-size: 0.9rem;
      align-self: ${sender === "user" ? "flex-end" : "flex-start"};
      background: ${sender === "user" ? "#e74c3c" : "#f8f9fa"};
      color: ${sender === "user" ? "white" : "black"};
    `;

      div.innerText = text;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
      return div;
    }

    function addTyping() {
      const messages = document.getElementById("chatMessages");
      const div = document.createElement("div");
      div.id = "typing_" + Date.now();
      div.style.cssText = `
      padding: 10px 14px;
      border-radius: 12px 12px 12px 0;
      max-width: 85%;
      font-size: 0.9rem;
      background: #f8f9fa;
      color: #999;
    `;
      div.innerText = "AI is typing...";
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
      return div.id;
    }

    function removeTyping(id) {
      const el = document.getElementById(id);
      if (el) el.remove();
    }

    async function planTrip(listingId) {
      const days = document.getElementById("tripDays").value;
      if (!days || days < 1) {
        alert("Please enter number of days!");
        return;
      }
      document.getElementById("tripLoading").style.display = "block";
      document.getElementById("tripBtn").disabled = true;
      document.getElementById("tripBtn").innerText = "Planning...";
      document.getElementById("tripPlanBox").style.display = "none";

      try {
        const response = await fetch(`/listings/${listingId}/trip-planner`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ days }),
        });
        const data = await response.json();
        if (data.success) {
          document.getElementById("tripContent").innerText = data.itinerary;
          document.getElementById("tripPlanBox").style.display = "block";
          document.getElementById("tripPlanBox").scrollIntoView({ behavior: "smooth" });
        } else {
          alert(data.message || "Trip planning failed!");
        }
      } catch (err) {
        alert("Something went wrong!");
      }
      document.getElementById("tripLoading").style.display = "none";
      document.getElementById("tripBtn").disabled = false;
      document.getElementById("tripBtn").innerText = "✨ Plan";
    }

    async function summarizeReviews(listingId) {
      document.getElementById("summaryLoading").style.display = "block";
      document.getElementById("summarizeBtn").disabled = true;
      document.getElementById("summarizeBtn").innerText = "Summarizing...";
      document.getElementById("summaryBox").style.display = "none";

      try {
        const response = await fetch(`/listings/${listingId}/summarize-reviews`);
        const data = await response.json();
        if (data.success) {
          document.getElementById("summaryText").innerText = data.summary;
          document.getElementById("summaryBox").style.display = "block";
        } else {
          alert(data.message || "Summary failed!");
        }
      } catch (err) {
        alert("Something went wrong!");
      }
      document.getElementById("summaryLoading").style.display = "none";
      document.getElementById("summarizeBtn").disabled = false;
      document.getElementById("summarizeBtn").innerText = "✨ AI Summary";
    }
  </script>