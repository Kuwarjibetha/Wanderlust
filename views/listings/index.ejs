<%- layout("/layouts/boilerplate") %>

<div class="container-fluid px-3 px-md-4 mt-3" style="max-width: 1200px; margin: auto;">

  <!-- ── Search & Filter Bar ── -->
  <form action="/listings" method="GET" class="mb-4">
    <div class="card border-0 shadow-sm rounded-4 p-3">

      <!-- Mobile: stacked, Desktop: inline -->
      <div class="row g-2 align-items-end">

        <!-- Search -->
        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold small">🔍 Search</label>
          <input
            type="text"
            name="search"
            class="form-control rounded-3"
            placeholder="Title or location..."
            value="<%= search %>"
          />
        </div>

        <!-- Country -->
        <div class="col-6 col-md-3">
          <label class="form-label fw-semibold small">🌍 Country</label>
          <input
            type="text"
            name="country"
            class="form-control rounded-3"
            placeholder="e.g. India"
            value="<%= country %>"
          />
        </div>

        <!-- Min Price -->
        <div class="col-3 col-md-2">
          <label class="form-label fw-semibold small">💰 Min ₹</label>
          <input
            type="number"
            name="minPrice"
            class="form-control rounded-3"
            placeholder="0"
            value="<%= minPrice %>"
          />
        </div>

        <!-- Max Price -->
        <div class="col-3 col-md-2">
          <label class="form-label fw-semibold small">🤑 Max ₹</label>
          <input
            type="number"
            name="maxPrice"
            class="form-control rounded-3"
            placeholder="99999"
            value="<%= maxPrice %>"
          />
        </div>

        <!-- Search Button -->
        <div class="col-12 col-md-1">
          <button type="submit" class="btn btn-danger w-100 rounded-3">
            Go
          </button>
        </div>

      </div>

      <!-- Active filters info -->
      <% if (search || country || minPrice || maxPrice) { %>
        <div class="mt-2 d-flex align-items-center gap-2 flex-wrap">
          <a href="/listings" class="btn btn-sm btn-outline-secondary rounded-3">
            ✕ Clear
          </a>
          <span class="text-muted" style="font-size:0.85rem;">
            <%= allListings.length %> result<%= allListings.length !== 1 ? "s" : "" %> found
          </span>
          <% if (search) { %>
            <span class="badge bg-danger rounded-pill">"<%= search %>"</span>
          <% } %>
          <% if (country) { %>
            <span class="badge bg-danger rounded-pill"><%= country %></span>
          <% } %>
          <% if (minPrice || maxPrice) { %>
            <span class="badge bg-danger rounded-pill">
              ₹<%= minPrice || "0" %> — ₹<%= maxPrice || "∞" %>
            </span>
          <% } %>
        </div>
      <% } %>

    </div>
  </form>

  <!-- ── Listings Grid ── -->
  <% if (allListings.length === 0) { %>
    <div class="text-center py-5">
      <div style="font-size: 4rem;">🔍</div>
      <h5 class="mt-3 fw-bold">No listings found!</h5>
      <p class="text-muted">Try different search terms or clear filters.</p>
      <a href="/listings" class="btn btn-danger px-4 rounded-3">Show All</a>
    </div>
  <% } else { %>
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
      <% for(let listing of allListings) { %>
        <div class="col">
          <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative listing-card">

            <!-- ❤️ Wishlist Button -->
            <% if (currUser && currUser.role === "guest") { %>
              <%
                let isWishlisted = currUser.wishlist &&
                currUser.wishlist.some(id => id.toString() === listing._id.toString());
              %>
              <form action="/wishlist/<%= listing._id %>" method="POST"
                    style="position:absolute; top:10px; right:10px; z-index:10;">
                <button
                  class="btn btn-sm rounded-circle shadow"
                  style="background:white; border:none; width:36px; height:36px; font-size:1rem;"
                  title="<%= isWishlisted ? 'Remove from wishlist' : 'Add to wishlist' %>"
                >
                  <%= isWishlisted ? "❤️" : "🤍" %>
                </button>
              </form>
            <% } %>

            <!-- Image -->
            <a href="/listings/<%= listing._id %>" class="text-decoration-none">
              <img
                src="<%= listing.image.url %>"
                class="card-img-top"
                alt="listing"
                style="height: 210px; object-fit: cover;"
              />
            </a>

            <!-- Card Body -->
            <div class="card-body px-3 pb-3">
              <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
                <p class="fw-bold mb-1"><%= listing.title %></p>
                <p class="text-muted mb-1" style="font-size:0.85rem;">
                  📍 <%= listing.location %>, <%= listing.country %>
                </p>
                <p class="mb-0">
                  <span class="text-danger fw-bold">
                    &#8377;<%= listing.price.toLocaleString("en-in") %>
                  </span>
                  <span class="text-muted" style="font-size:0.85rem;">/night</span>
                </p>
              </a>
            </div>

          </div>
        </div>
      <% } %>
    </div>
    <div class="space"></div>
  <% } %>

</div>
