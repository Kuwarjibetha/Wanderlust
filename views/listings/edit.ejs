<% layout("/layouts/boilerplate") %>
    <div class="container mt-4" style="max-width: 700px;">
        <h3 class="fw-bold mb-4">Edit Your Listing ✏️</h3>

        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" enctype="multipart/form-data">

            <div class="mb-3">
                <label class="form-label fw-semibold">Title</label>
                <input name="listing[title]" value="<%= listing.title %>" type="text" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="listing[description]" class="form-control"
                    rows="4"><%= listing.description %></textarea>
            </div>

            <!--  Updated image section -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Property Image</label>
                <!-- Show current image -->
                <img src="<%= listing.image.url %>" class="w-100 rounded-3 mb-2"
                    style="height: 200px; object-fit: cover;" alt="current listing image" />
                <input type="file" name="listing[image]" class="form-control" accept="image/*" />
                <small class="text-muted">Leave empty to keep current image</small>
            </div>

            <div class="row">
                <div class="mb-3 col-md-4">
                    <label class="form-label fw-semibold">Price / night</label>
                    <input name="listing[price]" value="<%= listing.price %>" type="number" class="form-control"
                        required />
                </div>
                <div class="mb-3 col-md-8">
                    <label class="form-label fw-semibold">Location</label>
                    <input name="listing[location]" value="<%= listing.location %>" type="text" class="form-control"
                        required />
                </div>
            </div>
            <div class="row">
                <div class="mb-3 col-md-4">
                    <label class="form-label fw-semibold">
                        Nearby Place
                    </label>

                    <select name="listing[nearbyPlace.type]" class="form-select" required>
                        <option value="" selected disabled><%= listing.nearbyPlace.type %></option>

                        <option value="Airport">✈️ Airport</option>
                        <option value="Railway Station">🚃 Railway Station</option>
                        <option value="Metro Station"> 🚇Metro Station</option>
                        <option value="Bus Stand">🚌 Bus Stand</option>
                        <option value="Hospital">🏥 Hospital</option>
                        <option value="Restaurant">🍽️ Restaurant</option>
                        <option value="Shopping Mall">🛍️ Shopping Mall</option>
                        <option value="Tourist Attraction">📸 Tourist Attraction</option>
                        <option value="Beach">🏖️ Beach</option>
                        <option value="Temple">🛕 Temple</option>
                        <option value="Park">🌳 Park</option>
                        <option value="University">🎓 University</option>
                        <option value="Market">🛒 Market</option>
                    </select>
                </div>
                <div class="mb-3 col-md-4">
                    <label class="form-label fw-semibold">Near name</label>
                    <input type="text" name="listing[nearbyPlace.name]" class="form-control"
                        value="<%= listing.nearbyPlace.name %>" />
                </div>
                <div class="mb-3 col-md-4">
                    <label class="form-label fw-semibold">Distance</label>
                    <input type="text" name="listing[nearbyPlace.distance]" class="form-control"
                        value="<%= listing.nearbyPlace.distance %>" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Country</label>
                <input name="listing[country]" value="<%= listing.country %>" type="text" class="form-control"
                    required />
            </div>
            <!-- Max Persons -->
            <div class="mb-3">
                <label class="form-label fw-semibold">👥 Max Persons Allowed</label>
                <input type="number" name="listing[maxPersons]" class="form-control"
                    value="<%= listing.maxPersons || 1 %>" min="1" max="20" required />
                <small class="text-muted">Maximum number of guests allowed</small>
            </div>

            <button class="btn btn-danger w-100 py-2 mt-2">Save Changes</button>

        </form>
    </div>