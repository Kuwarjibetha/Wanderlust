<%- layout("/layouts/boilerplate") %>

  <div class="container mt-4" style="max-width: 900px;">
    <h3 class="fw-bold mb-1">My Bookings 🧳</h3>
    <p class="text-muted mb-4">All your upcoming and past stays</p>
    <hr>

    <% if (bookings.length===0) { %>
      <div class="text-center py-5">
        <div style="font-size: 4rem;">🏖️</div>
        <h5 class="mt-3">No bookings yet!</h5>
        <p class="text-muted">Start exploring and book your perfect stay.</p>
        <a href="/listings" class="btn btn-danger px-4">Browse Listings</a>
      </div>
      <% } else { %>
        <div class="row g-4">
          <% for (let booking of bookings) { %>
            <div class="col-md-6">
              <div class="card border rounded-4 shadow-sm overflow-hidden h-100">

                <!-- Image -->
                <img src="<%= booking.listing.image.url %>" class="card-img-top"
                  style="height: 200px; object-fit: cover;" alt="listing" />

                <div class="card-body p-3">
                  <!-- Title & Location -->
                  <h5 class="fw-bold mb-1">
                    <%= booking.listing.title %>
                  </h5>
                  <p class="text-muted mb-3" style="font-size: 0.9rem;">
                    📍 <%= booking.listing.location %>, <%= booking.listing.country %>
                  </p>

                  <!-- Booking Info -->
                  <div class="d-flex flex-column gap-1 mb-3">
                    <div class="d-flex justify-content-between">
                      <span class="text-muted">📅 Check-in</span>
                      <span class="fw-semibold">
                        <%= booking.checkIn.toDateString() %>
                      </span>
                    </div>
                    <div class="d-flex justify-content-between">
                      <span class="text-muted">📅 Check-out</span>
                      <span class="fw-semibold">
                        <%= booking.checkOut.toDateString() %>
                      </span>
                    </div>
                    <div class="d-flex justify-content-between">
                      <span class="text-muted">👥 Guests</span>
                      <span class="fw-semibold">
                        <%= booking.guests %>
                      </span>
                    </div>
                    <div class="d-flex justify-content-between">
                      <span class="text-muted">Total</span>
                      <span class="fw-bold text-danger">
                        &#8377;<%= booking.totalPrice.toLocaleString("en-in") %>
                      </span>
                    </div>
                  </div>

                  <!-- Status Badge -->
                  <span class="badge bg-success mb-3">
                    <%= booking.status %>
                  </span>

                  <!-- Cancel Button -->
                  <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST">
                    <button class="btn btn-outline-danger w-100 rounded-3">
                      Cancel Booking
                    </button>
                  </form>
                </div>

              </div>
            </div>
            <% } %>
        </div>
        <% } %>
  </div>